# ─── Gateway (API organizacional, compatible OpenAI) ─────────────────────────
# Puerto donde el gateway expone la API. Apunta tu dominio a este puerto.
GATEWAY_PORT=8080
# API key que deben enviar los proyectos consumidores en "Authorization: Bearer <key>".
# GENERA UNA FUERTE, p. ej.:  python -c "import secrets; print(secrets.token_hex(24))"
LLM_API_KEY=

# ─── Open WebUI (chat para humanos) ──────────────────────────────────────────
WEBUI_PORT=3000

# ─── Modelo local ────────────────────────────────────────────────────────────
# Se descarga automáticamente al levantar (servicio ollama-init).
# Alternativas: llama3.1:8b, deepseek-r1:7b, qwen2.5:14b-instruct (más pesado).
OLLAMA_MODEL=qwen2.5:7b-instruct
