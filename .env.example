# ─── Gateway legacy (nginx, API compatible OpenAI -> Ollama directo) ─────────
# Puerto donde el gateway nginx expone la API. Apunta tu dominio a este puerto.
GATEWAY_PORT=8080
# API key única que deben enviar los proyectos en "Authorization: Bearer <key>".
# GENERA UNA FUERTE, p. ej.:  python -c "import secrets; print(secrets.token_hex(24))"
LLM_API_KEY=

# ─── Open WebUI (chat para humanos) ──────────────────────────────────────────
WEBUI_PORT=3000
# Permite que cualquier usuario con cuenta válida use los modelos base
# (el control de acceso real lo hace gateway-api por API key).
BYPASS_MODEL_ACCESS_CONTROL=true

# ─── Modelo local ────────────────────────────────────────────────────────────
# Se descarga automáticamente al levantar (servicio ollama-init).
#   DEV (PC ~16 GB, sin GPU):  qwen2.5:3b-instruct
#   PROD (servidor ~90 GB):    qwen2.5:14b-instruct
OLLAMA_MODEL=qwen2.5:3b-instruct
# Slots de inferencia concurrentes. En CPU los slots comparten núcleos: más slots
# mejora el reparto/latencia, NO el throughput, y gasta más RAM (KV-cache por slot).
OLLAMA_NUM_PARALLEL=2

# ─── Gateway-API (FastAPI: seguridad + estandarización sobre Open WebUI) ──────
GATEWAY_API_PORT=8090
# Key de servicio admin de Open WebUI (solo para provisión de usuarios /admin/*).
OPENWEBUI_ADMIN_KEY=
# Protege los endpoints /admin/* del gateway (header X-Admin-Key). GENERA UNA FUERTE.
ADMIN_BOOTSTRAP_KEY=

# Anti prompt-injection (llm-guard).
#   DEV: INSTALL_GUARD=false + GUARD_ENABLED=false  (imagen ligera, sin torch; 16 GB no aguanta el guard)
#   PROD: INSTALL_GUARD=true + GUARD_ENABLED=true
INSTALL_GUARD=false
GUARD_ENABLED=false
GUARD_USE_ONNX=false
# Umbral de PromptInjection (0-1).
GUARD_PI_THRESHOLD=0.95
# Modelo de prompt-injection del scanner de llm-guard (inglés). Normalmente vacío;
# para multilingüe usa la etapa PromptGuard (abajo) en vez de este.
GUARD_PI_MODEL=
# Token de HuggingFace para modelos gated (Meta Prompt Guard 2 multilingüe).
# Acepta la licencia en huggingface.co/meta-llama/Llama-Prompt-Guard-2-86M y pega el token.
HF_TOKEN=

# Concurrencia hacia el backend. Mantener alineado con OLLAMA_NUM_PARALLEL.
MAX_CONCURRENCY=2
# Segundos que una petición espera un slot libre antes de recibir 429.
QUEUE_TIMEOUT=30

# System prompt fijo del servidor (defensa estructural). Vacío = sin system prompt forzado.
# (Si usas policy.yaml, el system prompt se define ahí en su lugar.)
SYSTEM_PROMPT=
# Ruta del policy.yaml dentro del contenedor. Si el archivo no existe, el guard
# deriva la política de estas variables de entorno. Ver gateway-api/policy.example.yaml.
POLICY_FILE=policy.yaml
